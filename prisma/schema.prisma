generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ReportStatus {
  QUEUED
  RESEARCHING
  DRAFTED
  COMPLETED
  FAILED
}

model Report {
  id              String         @id @default(cuid())
  agencyName      String
  city            String
  state           String
  status          ReportStatus   @default(QUEUED)
  summary         String?
  companySnapshot Json?
  riskSignals     Json?
  growthSignals   Json?
  talkingPoints   Json?
  generatedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  sources         ReportSource[]
  usageEvents     UsageEvent[]

  @@index([createdAt])
  @@index([status])
}

model ReportSource {
  id         String   @id @default(cuid())
  reportId   String
  title      String
  url        String
  sourceType String
  createdAt  DateTime @default(now())
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model UsageEvent {
  id         String   @id @default(cuid())
  reportId   String?
  eventType  String
  metadata   Json?
  createdAt  DateTime @default(now())
  report     Report?  @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([reportId])
}
